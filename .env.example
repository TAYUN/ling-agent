# ============================================
# Ling Agent 环境变量配置
# ============================================
#
# 配置优先级（高 → 低）：
#   命令行参数 > 环境变量 > .ling.json > 默认值
#
# 变量命名规范：
#   LING_*        — Ling Agent 专用变量（推荐）
#   LLM_*         — 兼容 ch01 等工具的变量（备用）
# ============================================

# ---- 必须配置 ----
# API Key（二选一，推荐使用 LING_ 前缀）
# LING_API_KEY=your-api-key-here

# 兼容旧项目的变量名，与 LING_API_KEY 二选一即可
# LLM_API_KEY=sk-your-fallback-api-key

# ---- 可选：Provider / 模型选择 ----
# 支持的 provider：volcano | claude | openai
# 默认值：volcano
# LING_PROVIDER=volcano

# 模型名称
# 各 provider 的默认模型：
#   volcano → doubao-1.5-pro-32k-250115
#   claude  → claude-sonnet-4-20250514
#   openai  → gpt-5.4
# 覆盖方式（三选一）：
#   LING_MODEL=doubao-1.5-pro-32k-250115
#   或 LLM_MODEL=gpt-4o  （兼容旧项目）
#   或 .ling.json 中的 model 字段
# LING_MODEL=doubao-1.5-pro-32k-250115

# ---- 可选：自定义 API 地址 ----
# 默认情况下，各 provider 使用官方默认地址：
#   volcano → https://ark.cn-beijing.volces.com/api/v3
#   claude  → https://api.anthropic.com
#   openai  → https://api.openai.com
# 如需代理或自托管服务，可覆盖：
# LING_BASE_URL=https://your-proxy.example.com/v1
# 或兼容变量：
# LLM_BASE_URL=https://your-proxy.example.com/v1

# ============================================
# 常见场景示例
# ============================================

# --- 场景 1：火山引擎（默认） ---
# LING_PROVIDER=volcano
# LING_API_KEY=your-volcano-api-key
# LING_MODEL=doubao-1.5-pro-32k-250115

# --- 场景 2：Claude（Anthropic） ---
# LING_PROVIDER=claude
# LING_API_KEY=sk-ant-your-claude-api-key
# LING_MODEL=claude-sonnet-4-20250514

# --- 场景 3：OpenAI 兼容（含代理） ---
LING_PROVIDER=openai
LING_API_KEY=your-openai-api-key
LING_MODEL=gpt-5.4-mini
LING_BASE_URL=youer-base-url

# --- 场景 4：仅使用 LLM_ 前缀（兼容 ch01） ---
# LLM_API_KEY=sk-your-api-key
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1